# Smart Plant Mobile App Env Variables
# Copy this file to .env and fill in your values

# API Configuration (if connecting to backend later)
# REACT_APP_API_URL=http://localhost:3000
# REACT_APP_API_KEY=your_api_key_here

# Notification Settings
# REACT_APP_NOTIFICATION_SERVICE_KEY=your_key_here

# Authentication
# REACT_APP_AUTH_PROVIDER=firebase | supabase | custom
