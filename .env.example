# Smart Plant Mobile App - Environment Variables Template
# Copy this file to .env and fill in your values for your environment

# ========== PRODUCTION DEPLOYMENT ==========
# Production API URL (update with your backend deployment URL)
# REACT_APP_API_URL=https://yourapp.railway.app
# EXPO_PUBLIC_API_URL=https://yourapp.railway.app

# ========== DEVELOPMENT (Local Testing) ==========
# Development API URL - Replace with your PC's actual IP address
# Find IP with: ipconfig (Look for IPv4 Address)
# REACT_APP_API_URL=http://192.168.1.10:8000
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000

# ========== NOTIFICATIONS (optional) ==========
# REACT_APP_NOTIFICATION_SERVICE_KEY=your_key_here

# ========== FEATURE FLAGS (optional) ==========
# REACT_APP_DEBUG_MODE=false

